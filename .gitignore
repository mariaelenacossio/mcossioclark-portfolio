# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# supabase CLI local state (linked-project ref, versions, pooler url)
supabase/.temp/

# typescript
*.tsbuildinfo
next-env.d.ts

# Dead components removed in the A3/A6 cleanup. A local file-restore tool
# (editor "Local History" / a versioned cloud sync) keeps resurrecting them
# on disk from old snapshots - they import nothing and are NOT on the live
# site. Ignored so `git add -A` can't silently re-add them and undo the
# cleanup. Do not reuse these exact paths for new components.
/app/components/ui/CountUpStat.tsx
/app/components/ui/ScrollReveal.tsx
/app/components/ui/CustomCursor.tsx
/app/components/ui/NoiseOverlay.tsx
